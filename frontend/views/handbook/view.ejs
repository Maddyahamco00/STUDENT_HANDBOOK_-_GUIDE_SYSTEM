<%- include('../layout', { body: `
<div class="handbook-view-page">
  <div class="handbook-header">
    <h1><%= handbook.title %></h1>
    <% if (handbook.description) { %>
      <p><%= handbook.description %></p>
    <% } %>
  </div>
  
  <% if (sections && sections.length > 0) { %>
    <div class="handbook-sections">
      <% sections.forEach(function(section) { %>
        <div class="handbook-section" id="section-<%= section.id %>">
          <h2><%= section.title %></h2>
          <div class="section-content">
            <%- section.content %>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="empty-state">
      <p>No sections available in this handbook yet.</p>
    </div>
  <% } %>
  
  <div class="handbook-nav">
    <a href="/handbook" class="btn btn-secondary">← Back to Handbooks</a>
  </div>
</div>
` }) %>