<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof handbook !== 'undefined' && handbook ? handbook.title : 'Handbook' %> - Student Handbook Guide System</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="main-header">
    <div class="container">
      <div class="logo">
        <a href="/">Student Handbook</a>
      </div>
      <nav class="main-nav">
        <a href="/dashboard">Dashboard</a>
        <a href="/handbook">Handbook</a>
        <a href="/registration/steps">Registration</a>
        <a href="/dashboard/profile">Profile</a>
        <a href="/auth/logout" class="btn-logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="main-content">
    <div class="handbook-view-page">
      <div class="handbook-header">
        <h1><%= typeof handbook !== 'undefined' && handbook ? handbook.title : 'Handbook' %></h1>
        <% if (typeof handbook !== 'undefined' && handbook && handbook.description) { %>
          <p><%= handbook.description %></p>
        <% } %>
      </div>
      
      <% if (typeof sections !== 'undefined' && sections && sections.length > 0) { %>
        <div class="handbook-sections">
          <% sections.forEach(function(section) { %>
            <div class="handbook-section" id="section-<%= section.id %>">
              <h2><%= section.title %></h2>
              <div class="section-content">
                <%- section.content %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <p>No sections available in this handbook yet.</p>
        </div>
      <% } %>
      
      <div class="handbook-nav">
        <a href="/handbook" class="btn btn-secondary">← Back to Handbooks</a>
      </div>
    </div>
  </main>

  <footer class="main-footer">
    <div class="container">
      <p>&copy; 2026 Student Handbook Guide System. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>