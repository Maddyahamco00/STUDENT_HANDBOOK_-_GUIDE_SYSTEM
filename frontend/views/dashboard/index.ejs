<%- include('../layout', { body: `
<div class="dashboard">
  <div class="dashboard-header">
    <h1>Welcome, <%= user.name %>!</h1>
    <p>Track your registration progress and stay updated with announcements.</p>
  </div>

  <div class="dashboard-stats">
    <div class="stat-card">
      <div class="stat-icon">📋</div>
      <div class="stat-content">
        <h3><%= stats.total_steps || 0 %></h3>
        <p>Total Steps</p>
      </div>
    </div>
    
    <div class="stat-card stat-completed">
      <div class="stat-icon">✅</div>
      <div class="stat-content">
        <h3><%= stats.completed_steps || 0 %></h3>
        <p>Completed</p>
      </div>
    </div>
    
    <div class="stat-card stat-pending">
      <div class="stat-icon">⏳</div>
      <div class="stat-content">
        <h3><%= stats.pending_steps || 0 %></h3>
        <p>Pending</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon">📘</div>
      <div class="stat-content">
        <h3><%= handbooks.length %></h3>
        <p>Handbooks</p>
      </div>
    </div>
  </div>

  <div class="dashboard-grid">
    <div class="dashboard-section">
      <div class="section-header">
        <h2>📢 Announcements</h2>
        <a href="/registration/steps" class="btn btn-sm">View All</a>
      </div>
      
      <% if (announcements && announcements.length > 0) { %>
        <div class="announcements-list">
          <% announcements.forEach(function(announcement) { %>
            <div class="announcement-item">
              <h3><%= announcement.title %></h3>
              <p><%= announcement.message %></p>
              <% if (announcement.deadline) { %>
                <span class="deadline">Deadline: <%= new Date(announcement.deadline).toLocaleDateString() %></span>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p class="empty-state">No announcements at this time.</p>
      <% } %>
    </div>

    <div class="dashboard-section">
      <div class="section-header">
        <h2>📘 Available Handbooks</h2>
        <a href="/handbook" class="btn btn-sm">View All</a>
      </div>
      
      <% if (handbooks && handbooks.length > 0) { %>
        <div class="handbooks-list">
          <% handbooks.forEach(function(handbook) { %>
            <div class="handbook-item">
              <h3><a href="/handbook/<%= handbook.id %>"><%= handbook.title %></a></h3>
              <p><%= handbook.description || 'No description available' %></p>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p class="empty-state">No handbooks available yet.</p>
      <% } %>
    </div>
  </div>

  <div class="dashboard-section full-width">
    <div class="section-header">
      <h2>📝 Registration Progress</h2>
      <a href="/registration/steps" class="btn btn-primary">View Steps</a>
    </div>
    
    <% if (progress && progress.length > 0) { %>
      <div class="progress-list">
        <% progress.forEach(function(p) { %>
          <div class="progress-item">
            <div class="progress-status <%= p.status %>">
              <% if (p.status === 'completed') { %>✓<% } else if (p.status === 'in_progress') { %>⟳<% } else { %>○<% } %>
            </div>
            <div class="progress-content">
              <h4><%= p.step_title %></h4>
              <p><%= p.description %></p>
              <% if (p.deadline) { %>
                <span class="deadline">Due: <%= new Date(p.deadline).toLocaleDateString() %></span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <p class="empty-state">No registration steps available yet.</p>
    <% } %>
  </div>
</div>
` }) %>