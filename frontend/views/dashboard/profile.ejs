<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile - Student Handbook Guide System</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="main-header">
    <div class="container">
      <div class="logo">
        <a href="/">Student Handbook</a>
      </div>
      <nav class="main-nav">
        <a href="/dashboard">Dashboard</a>
        <a href="/handbook">Handbook</a>
        <a href="/registration/steps">Registration</a>
        <a href="/dashboard/profile">Profile</a>
        <a href="/auth/logout" class="btn-logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="main-content">
    <div class="profile-page">
      <h1>My Profile</h1>
      
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>
      
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      
      <div class="profile-card">
        <form action="/dashboard/profile" method="POST" class="profile-form">
          <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" value="<%= typeof user !== 'undefined' && user ? user.name : '' %>" required>
          </div>
          
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" value="<%= typeof user !== 'undefined' && user ? user.email : '' %>" required>
          </div>
          
          <div class="form-group">
            <label for="role">Account Type</label>
            <input type="text" id="role" value="<%= typeof user !== 'undefined' && user ? user.role : '' %>" disabled>
            <small>Contact admin to change your account type.</small>
          </div>
          
          <hr>
          
          <h3>Change Password (Optional)</h3>
          
          <div class="form-group">
            <label for="current_password">Current Password</label>
            <input type="password" id="current_password" name="current_password" placeholder="Enter current password">
          </div>
          
          <div class="form-group">
            <label for="new_password">New Password</label>
            <input type="password" id="new_password" name="new_password" placeholder="Enter new password" minlength="6">
          </div>
          
          <button type="submit" class="btn btn-primary">Update Profile</button>
        </form>
      </div>
    </div>
  </main>

  <footer class="main-footer">
    <div class="container">
      <p>&copy; 2026 Student Handbook Guide System. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>