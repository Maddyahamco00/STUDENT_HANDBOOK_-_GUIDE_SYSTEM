<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Student Handbook Guide System</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="main-header">
    <div class="container">
      <div class="logo">
        <a href="/">Student Handbook</a>
      </div>
      <nav class="main-nav">
        <a href="/">Home</a>
        <a href="/auth/register" class="btn-primary">Register</a>
      </nav>
    </div>
  </header>

  <main class="main-content">
    <div class="auth-page">
      <div class="auth-container">
        <div class="auth-card">
          <h1>Login</h1>
          <p class="auth-subtitle">Welcome back! Please login to continue.</p>
          
          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
          <% } %>
          
          <% if (typeof query !== 'undefined' && query.registered) { %>
            <div class="alert alert-success">Registration successful! Please login.</div>
          <% } %>
          
          <form action="/auth/login" method="POST" class="auth-form">
            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" required placeholder="Enter your email">
            </div>
            
            <div class="form-group">
              <label for="password">Password</label>
              <input type="password" id="password" name="password" required placeholder="Enter your password">
            </div>
            
            <button type="submit" class="btn btn-primary btn-block">Login</button>
          </form>
          
          <p class="auth-footer">
            Don't have an account? <a href="/auth/register">Register here</a>
          </p>
        </div>
      </div>
    </div>
  </main>

  <footer class="main-footer">
    <div class="container">
      <p>&copy; 2026 Student Handbook Guide System. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>