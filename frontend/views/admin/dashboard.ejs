<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Student Handbook Guide System</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="main-header">
    <div class="container">
      <div class="logo">
        <a href="/">Student Handbook</a>
      </div>
      <nav class="main-nav">
        <a href="/dashboard">Dashboard</a>
        <a href="/handbook">Handbook</a>
        <a href="/registration/steps">Registration</a>
        <a href="/admin/dashboard">Admin Panel</a>
        <a href="/dashboard/profile">Profile</a>
        <a href="/auth/logout" class="btn-logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="main-content">
    <div class="admin-dashboard">
      <h1>Admin Dashboard</h1>
      <p>Manage your institution's content and users.</p>
      
      <div class="admin-stats">
        <div class="stat-card">
          <div class="stat-icon">👥</div>
          <div class="stat-content">
            <h3><%= typeof stats !== 'undefined' && stats ? stats.totalUsers : 0 %></h3>
            <p>Total Users</p>
          </div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon">📘</div>
          <div class="stat-content">
            <h3><%= typeof stats !== 'undefined' && stats ? stats.totalHandbooks : 0 %></h3>
            <p>Handbooks</p>
          </div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon">📝</div>
          <div class="stat-content">
            <h3><%= typeof stats !== 'undefined' && stats ? stats.totalSteps : 0 %></h3>
            <p>Registration Steps</p>
          </div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon">📢</div>
          <div class="stat-content">
            <h3><%= typeof stats !== 'undefined' && stats ? stats.totalAnnouncements : 0 %></h3>
            <p>Announcements</p>
          </div>
        </div>
      </div>
      
      <div class="admin-grid">
        <div class="admin-card">
          <h2>📘 Handbooks</h2>
          <p>Create and manage school handbooks and sections.</p>
          <a href="/admin/handbooks" class="btn btn-primary">Manage Handbooks</a>
        </div>
        
        <div class="admin-card">
          <h2>📝 Registration Steps</h2>
          <p>Set up registration workflow and deadlines.</p>
          <a href="/admin/registration-steps" class="btn btn-primary">Manage Steps</a>
        </div>
        
        <div class="admin-card">
          <h2>👥 Users</h2>
          <p>View and manage registered students.</p>
          <a href="/admin/users" class="btn btn-primary">Manage Users</a>
        </div>
        
        <div class="admin-card">
          <h2>📢 Announcements</h2>
          <p>Post announcements and notifications.</p>
          <a href="/admin/announcements" class="btn btn-primary">Manage Announcements</a>
        </div>
        
        <% if (typeof user !== 'undefined' && user && user.role === 'super_admin') { %>
        <div class="admin-card">
          <h2>🏫 Institutions</h2>
          <p>Manage schools and institutions.</p>
          <a href="/admin/institutions" class="btn btn-primary">Manage Institutions</a>
        </div>
        <% } %>
      </div>
      
      <div class="admin-section">
        <h2>Recent Announcements</h2>
        <% if (typeof recentAnnouncements !== 'undefined' && recentAnnouncements && recentAnnouncements.length > 0) { %>
          <table class="data-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Message</th>
                <th>Deadline</th>
                <th>Created</th>
              </tr>
            </thead>
            <tbody>
              <% recentAnnouncements.forEach(function(ann) { %>
                <tr>
                  <td><%= ann.title %></td>
                  <td><%= ann.message.substring(0, 100) %>...</td>
                  <td><%= ann.deadline ? new Date(ann.deadline).toLocaleDateString() : 'No deadline' %></td>
                  <td><%= new Date(ann.created_at).toLocaleDateString() %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <p class="empty-state">No announcements yet.</p>
        <% } %>
      </div>
    </div>
  </main>

  <footer class="main-footer">
    <div class="container">
      <p>&copy; 2026 Student Handbook Guide System. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>